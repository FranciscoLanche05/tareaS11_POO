<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tareas11fx.controllers.ProductosController">

    <VBox spacing="15" styleClass="card">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <Label styleClass="card-title" text="Registro / Edición de Producto" />

        <GridPane hgap="20" vgap="12">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.3" />
                <ColumnConstraints percentWidth="33.3" />
                <ColumnConstraints percentWidth="33.3" />
            </columnConstraints>

            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label styleClass="field-label" text="Código del producto" />
                <TextField fx:id="txtCodigo" promptText="Ej: P001" />
            </VBox>

            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label styleClass="field-label" text="Nombre del producto" />
                <TextField fx:id="txtNombre" promptText="Ingrese el nombre" />
            </VBox>

            <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label styleClass="field-label" text="Categoría" />
                <ComboBox fx:id="cmbCategoria" maxWidth="1.7976931348623157E308" promptText="Seleccione una categoría" />
            </VBox>

            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label styleClass="field-label" text="Precio" />
                <TextField fx:id="txtPrecio" promptText="0.00" />
            </VBox>

            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label styleClass="field-label" text="Stock" />
                <TextField fx:id="txtStock" promptText="0" />
            </VBox>

            <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                <Label styleClass="field-label" text="Estado" />
                <ComboBox fx:id="cmbEstado" maxWidth="1.7976931348623157E308" promptText="Activo" />
            </VBox>
        </GridPane>

        <HBox spacing="10">
            <Button onAction="#nuevoProducto" styleClass="btn-nuevo" text="➕ Nuevo" />
            <Button onAction="#guardarProducto" styleClass="btn-guardar" text="💾 Guardar" />
            <Button onAction="#actualizarProducto" styleClass="btn-actualizar" text="✏ Actualizar" />
            <Button onAction="#eliminarProductoSeleccionado" styleClass="btn-eliminar-form" text="🗑 Eliminar" />
            <Button onAction="#limpiarFormulario" styleClass="btn-limpiar" text="🔄 Limpiar" />
        </HBox>
    </VBox>

    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label styleClass="card-title" text="📋 Lista de Productos" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtBuscar" onAction="#buscarProducto" promptText="🔍 Buscar producto..." />
        </HBox>

        <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCodigo" prefWidth="80" text="Código" />
                <TableColumn fx:id="colNombre" prefWidth="180" text="Nombre" />
                <TableColumn fx:id="colCategoria" prefWidth="120" text="Categoría" />
                <TableColumn fx:id="colPrecio" prefWidth="80" text="Precio" />
                <TableColumn fx:id="colStock" prefWidth="70" text="Stock" />
                <TableColumn fx:id="colEstado" prefWidth="90" text="Estado" />
                <TableColumn fx:id="colAcciones" prefWidth="100" text="Acciones" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>