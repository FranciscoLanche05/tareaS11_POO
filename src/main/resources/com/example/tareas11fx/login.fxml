<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@styles/login.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tareas11fx.controllers.LoginController">
    <VBox alignment="CENTER" maxWidth="380" spacing="12" styleClass="login-card">
        <padding>
            <Insets bottom="35" left="35" right="35" top="35" />
        </padding>

        <Label styleClass="logo-icon" text="🛒" />
        <Label styleClass="app-title" text="MiTienda" />
        <Label styleClass="app-subtitle" text="Sistema de Ventas" />

        <Label styleClass="form-title" text="Iniciar sesión" />

        <VBox spacing="5">
            <Label styleClass="field-label" text="Usuario" />
            <TextField fx:id="txtUsuario" promptText="Ej: admin" />
        </VBox>

        <VBox spacing="5">
            <Label styleClass="field-label" text="Contraseña" />
            <PasswordField fx:id="txtContrasena" promptText="••••••••" />
        </VBox>

        <VBox spacing="5">
            <Label styleClass="field-label" text="Rol" />
            <ComboBox fx:id="cmbRol" maxWidth="1.7976931348623157E308" promptText="— Seleccionar —" />
        </VBox>

        <Label fx:id="lblError" styleClass="error-label" wrapText="true" />

        <Button maxWidth="1.7976931348623157E308" onAction="#onIngresar" styleClass="btn-ingresar" text="➜ Ingresar" />

        <Label styleClass="hint-label" text="admin / 1234 / Administrador" />
    </VBox>
</StackPane>